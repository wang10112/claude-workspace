{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node claude/hooks/scripts/memory-capture.js",
            "async": true,
            "timeout": 5
          }
        ],
        "description": "Capture important operations to memory",
        "id": "post:memory-capture"
      }
    ]
  }
}
