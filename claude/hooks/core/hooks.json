{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node claude/hooks/scripts/quality-gate.js",
            "timeout": 10,
            "statusMessage": "Running quality checks..."
          }
        ],
        "description": "Quality gate: Check code quality after file changes",
        "id": "post:quality-gate"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node claude/hooks/scripts/security-scan.js",
            "if": "Bash(git commit *)",
            "timeout": 15,
            "statusMessage": "Running security scan..."
          }
        ],
        "description": "Security scan before git commit",
        "id": "pre:security-scan"
      }
    ]
  }
}
