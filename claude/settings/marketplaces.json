{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "marketplaces": [
    {
      "name": "official",
      "description": "Anthropic 官方技能市场",
      "url": "https://github.com/anthropics/anthropic-skills",
      "enabled": true
    },
    {
      "name": "community",
      "description": "社区技能市场",
      "url": "https://github.com/claude-community/skills",
      "enabled": false
    },
    {
      "name": "custom",
      "description": "自定义技能市场",
      "url": "https://github.com/your-org/claude-skills",
      "enabled": false
    }
  ],
  "skillSettings": {
    "autoUpdate": false,
    "updateInterval": "weekly",
    "allowedSources": [
      "github.com/anthropics/*",
      "github.com/claude-community/*"
    ]
  }
}
